
# App URL — tunnel subdomain for dev, production subdomain for prod
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Google Maps — https://console.cloud.google.com/apis/credentials
# Enable "Maps JavaScript API" for your project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Google OAuth — https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID)
# Add redirect URI: <APP_URL>/api/auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin email whitelist — comma-separated, leave empty to allow all in dev
ADMIN_EMAILS=""

# MongoDB
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bananaverse?retryWrites=true&w=majority"
